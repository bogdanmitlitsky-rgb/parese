<Window x:Class="Hotline_Main_Parsing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hotline_Main_Parsing"
        mc:Ignorable="d"
        Title="Hotline Parser"
        Height="640"
        Width="1180"
        MinHeight="560"
        MinWidth="1080"
        Icon="parser-logo.ico"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Topmost="True"
        Background="#F3F6FB"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InkBrush" Color="#152032" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7688" />
        <SolidColorBrush x:Key="LineBrush" Color="#D9E2EF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#93B4F8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFF5F5" />
            <Setter Property="BorderBrush" Value="#FECACA" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="104" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111B2E">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="54"
                            Height="54"
                            CornerRadius="12"
                            Background="#1E3A8A"
                            BorderBrush="#5B7CFA"
                            BorderThickness="1"
                            Margin="0,0,14,0">
                        <Canvas Width="54" Height="54">
                            <Rectangle Width="6" Height="16" RadiusX="2" RadiusY="2" Fill="#2DD4BF" Canvas.Left="13" Canvas.Top="28" />
                            <Rectangle Width="6" Height="23" RadiusX="2" RadiusY="2" Fill="#FB923C" Canvas.Left="23" Canvas.Top="21" />
                            <Rectangle Width="6" Height="31" RadiusX="2" RadiusY="2" Fill="#2DD4BF" Canvas.Left="33" Canvas.Top="13" />
                            <Ellipse Width="25" Height="25" Stroke="#FFFFFF" StrokeThickness="4" Canvas.Left="9" Canvas.Top="8" />
                            <Line X1="28" Y1="27" X2="43" Y2="42" Stroke="#FFFFFF" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Hotline Parser"
                                   Foreground="#FFFFFF"
                                   FontSize="27"
                                   FontWeight="Bold" />
                        <TextBlock Text="Парсинг цен Hotline и обновление Google Sheets"
                                   Foreground="#AEBBD0"
                                   FontSize="14"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </StackPanel>
                <WrapPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="18,0"
                            ItemHeight="42">
                    <Border Width="88"
                            Height="42"
                            Background="#17243A"
                            BorderBrush="#2C3E5F"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,5"
                            Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="ЦП"
                                       Foreground="#8EA0BA"
                                       FontSize="10"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="CpuUsageText"
                                       Text="0%"
                                       Foreground="#86EFAC"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Width="98"
                            Height="42"
                            Background="#17243A"
                            BorderBrush="#2C3E5F"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,5"
                            Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="RAM"
                                       Foreground="#8EA0BA"
                                       FontSize="10"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="RamUsageText"
                                       Text="0 МБ"
                                       Foreground="#86EFAC"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,1,0,0"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Width="122"
                            Height="42"
                            Background="#17243A"
                            BorderBrush="#2C3E5F"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,5"
                            Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Chrome"
                                       Foreground="#8EA0BA"
                                       FontSize="10"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="ChromeUsageText"
                                       Text="0 / 0 МБ"
                                       Foreground="#86EFAC"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Margin="0,2,0,0"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Width="88"
                            Height="42"
                            Background="#17243A"
                            BorderBrush="#2C3E5F"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,5">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="CPU °C"
                                       Foreground="#8EA0BA"
                                       FontSize="10"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="TemperatureText"
                                       Text="н/д"
                                       Foreground="#86EFAC"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,1,0,0"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button x:Name="bNormalizeOrientir"
                            Visibility="Collapsed"
                            Content="Обновить D по ОПТ"
                            Click="NormalizeOrientir_Click"
                            Width="170"
                            Margin="0,0,12,0" />
                    <Border x:Name="StatusBadge"
                            Background="#FFEDD5"
                            CornerRadius="8"
                            Padding="16,9"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Text="Ожидает запуска"
                                   Foreground="#9A3412"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <StackPanel>
                    <TextBlock Text="Управление"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="Выберите режимы и запустите обработку."
                               TextWrapping="Wrap"
                               Margin="0,6,0,22"
                               Foreground="{StaticResource MutedBrush}" />

                    <Button x:Name="bStart"
                            Content="Старт"
                            Click="Button_Click_1"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button x:Name="bStop"
                            Content="Стоп"
                            Click="bStop_Click"
                            IsEnabled="False"
                            Margin="0,10,0,0"
                            Style="{StaticResource DangerButtonStyle}" />
                    <Button x:Name="bSettings"
                            Content="Настройки"
                            Click="Button_ClickSetting"
                            Margin="0,10,0,0" />
                    <Button x:Name="bClearLog"
                            Content="Очистить журнал"
                            Click="ClearLog_Click"
                            Margin="0,10,0,0" />
                    <Button x:Name="bOpenLogs"
                            Content="Открыть логи"
                            Click="OpenLogs_Click"
                            Margin="0,10,0,0" />
                    <Button x:Name="bCompetitors"
                            Content="Конкуренты"
                            Click="OpenCompetitors_Click"
                            Margin="0,10,0,0" />
                    <Separator Margin="0,24,0,20" Background="{StaticResource LineBrush}" />

                    <TextBlock Text="Режимы"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,0,0,12" />
                    <CheckBox x:Name="CheckBoxDefault"
                              Content="Смартфоны"
                              IsChecked="True"
                              Click="CheckBoxDefault_Click" />
                    <CheckBox x:Name="CheckBoxAks"
                              Content="Аксессуары"
                              IsChecked="True"
                              Checked="CheckBoxAks_Checked"
                              Click="CheckBoxAks_Click" />

                    <Border Background="#EEF4FF"
                            BorderBrush="#C7D8FE"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,18,0,0">
                        <TextBlock Text="Остановка отменяет текущий цикл и возвращает управление после закрытия браузера."
                                   TextWrapping="Wrap"
                                   Foreground="#24436F"
                                   FontSize="12" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Журнал выполнения"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}" />
                            <TextBlock Text="Состояние парсинга, ошибки и прогресс обработки."
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,5,0,0" />
                            <TextBlock x:Name="StageText"
                                       Text="Текущий этап: ожидание запуска"
                                       Foreground="#2563EB"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,10,0,0" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="136"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Value, ElementName=pbStatus, StringFormat=\{0:0\}%}"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="23"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Осталось"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11" />
                                    <TextBlock x:Name="EtaText"
                                               Text="н/д"
                                               Foreground="#1D4ED8"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <ProgressBar x:Name="pbStatus"
                                 Grid.Row="1"
                                 Height="12"
                                 Minimum="0"
                                 Maximum="100"
                                 Margin="0,18,0,18"
                                 Value="0" />

                    <ListView Grid.Row="2"
                              x:Name="LogList"
                              Background="#F8FAFC"
                              BorderBrush="{StaticResource LineBrush}"
                              BorderThickness="1"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              FontSize="12">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="{Binding RowBackground}" />
                                <Setter Property="BorderBrush" Value="#E8EEF7" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="30" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#EEF4FF" />
                                <Setter Property="Foreground" Value="#34425A" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Время" Width="78">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TimeText}"
                                                       FontFamily="Consolas"
                                                       Foreground="#44546A"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       Margin="0" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Этап" Width="142">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ScopeText}"
                                                       FontFamily="Consolas"
                                                       Foreground="#1F365C"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       Margin="0" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Товар / сообщение" Width="560">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MessageText}"
                                                       Foreground="{StaticResource InkBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,0,0,0" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Статус" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFFFFF"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Center"
                                                    Margin="0">
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{Binding AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="РРЦ" Width="88">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RrcPriceText}"
                                                       FontFamily="Consolas"
                                                       Foreground="#7C3AED"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       Margin="0" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Было" Width="88">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OldPriceText}"
                                                       FontFamily="Consolas"
                                                       Foreground="#44546A"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       Margin="0" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Стало" Width="108">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding NewPriceText}"
                                                       FontFamily="Consolas"
                                                       Foreground="{Binding PriceBrush}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       Margin="0" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Прошло" Width="86">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ElapsedText}"
                                                       FontFamily="Consolas"
                                                       Foreground="#44546A"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       Margin="0" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="SettingsOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="#EAF3F6FB">
            <Border Margin="18"
                    Background="#F3F6FB"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <ContentControl x:Name="SettingsContent" />
            </Border>
        </Grid>
    </Grid>
</Window>
