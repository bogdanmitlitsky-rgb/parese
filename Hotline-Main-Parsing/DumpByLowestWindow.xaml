<Window x:Class="Hotline_Main_Parsing.DumpByLowestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товары по низу"
        Height="720"
        Width="1180"
        MinHeight="560"
        MinWidth="980"
        Icon="parser-logo.ico"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FB"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InkBrush" Color="#152032" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7688" />
        <SolidColorBrush x:Key="LineBrush" Color="#D9E2EF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="SuccessTextBrush" Color="#047857" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#B45309" />
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#DC2626" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Товары по низу"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource InkBrush}" />
                <TextBlock x:Name="SummaryText"
                           Text="База еще не загружена"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <Border x:Name="SaveStateBadge"
                    Grid.Column="1"
                    Height="32"
                    MinWidth="128"
                    Padding="12,0"
                    CornerRadius="16"
                    Background="#E9F8EF"
                    BorderBrush="#BBF7D0"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <TextBlock x:Name="SaveStateText"
                           Text="Сохранено"
                           Foreground="{StaticResource SuccessTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>

            <Button Grid.Column="3"
                    Content="Обновить базу"
                    Width="140"
                    Click="RefreshBase_Click" />
            <Button x:Name="SaveButton"
                    Grid.Column="5"
                    Content="Сохранить"
                    Width="120"
                    IsEnabled="False"
                    Click="Save_Click" />
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,18,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         TextChanged="Filter_Changed" />

                <ComboBox x:Name="SectionFilter"
                          Grid.Column="2"
                          Height="36"
                          VerticalContentAlignment="Center"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все разделы" IsSelected="True" />
                    <ComboBoxItem Content="Смартфоны" />
                    <ComboBoxItem Content="Аксессуары" />
                </ComboBox>

                <TextBlock Grid.Column="3"
                           Text="Отметь товары, которым нужно ставить цену под самый низкий нормальный оффер."
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="16,0,0,0" />

                <Button Grid.Column="4"
                        Content="Включить видимые"
                        Width="150"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SelectVisible_Click" />
                <Button Grid.Column="6"
                        Content="Снять видимые"
                        Width="130"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="UnselectVisible_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <DataGrid x:Name="ProductsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F8FAFC"
                      BorderThickness="0"
                      Margin="1">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="По низу"
                                            Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="82" />
                    <DataGridTextColumn Header="Раздел" Binding="{Binding Section}" IsReadOnly="True" Width="110" />
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="135" />
                    <DataGridTextColumn Header="Товар" Binding="{Binding Name}" IsReadOnly="True" Width="3*" />
                    <DataGridHyperlinkColumn Header="Hotline"
                                             Binding="{Binding Url}"
                                             ContentBinding="{Binding Url}"
                                             IsReadOnly="True"
                                             Width="180">
                        <DataGridHyperlinkColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <EventSetter Event="Hyperlink.RequestNavigate" Handler="HotlineLink_RequestNavigate" />
                            </Style>
                        </DataGridHyperlinkColumn.ElementStyle>
                    </DataGridHyperlinkColumn>
                    <DataGridTextColumn Header="Обновлено"
                                        Binding="{Binding LastSeenUtc, StringFormat={}{0:dd.MM HH:mm}}"
                                        IsReadOnly="True"
                                        Width="115" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Text="Изменения применятся со следующего запуска парсинга."
                   Foreground="{StaticResource MutedBrush}"
                   Margin="0,12,0,0" />
    </Grid>
</Window>
