<UserControl x:Class="Hotline_Main_Parsing.SettingsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Hotline_Main_Parsing"
             mc:Ignorable="d"
             Background="#F3F6FB"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InkBrush" Color="#152032" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7688" />
        <SolidColorBrush x:Key="LineBrush" Color="#D9E2EF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="0,0,0,6" />
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border Width="42"
                        Height="42"
                        CornerRadius="10"
                        Background="#111B2E"
                        Margin="0,0,12,0">
                    <Canvas Width="42" Height="42">
                        <Rectangle Width="5" Height="12" RadiusX="2" RadiusY="2" Fill="#2DD4BF" Canvas.Left="10" Canvas.Top="23" />
                        <Rectangle Width="5" Height="18" RadiusX="2" RadiusY="2" Fill="#FB923C" Canvas.Left="19" Canvas.Top="17" />
                        <Rectangle Width="5" Height="24" RadiusX="2" RadiusY="2" Fill="#2DD4BF" Canvas.Left="28" Canvas.Top="11" />
                        <Ellipse Width="19" Height="19" Stroke="#FFFFFF" StrokeThickness="3" Canvas.Left="7" Canvas.Top="7" />
                        <Line X1="22" Y1="22" X2="33" Y2="33" Stroke="#FFFFFF" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Настройки"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="После сохранения программа предложит перезапуск, чтобы сразу применить изменения."
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Закрыть"
                    Width="110"
                    Click="btnCloseSettings_Click" />
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <TabControl Name="tabControl1">
                <TabItem x:Name="tMain" Header="Основные" IsSelected="True">
                    <Grid Margin="8,20,8,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Время начала" />
                            <TextBox x:Name="tbStartTime" Loaded="tbStartTime_Loaded">
                                <TextBox.Text>
                                    <Binding Path="StartTime" UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <DataErrorValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Время завершения" />
                            <TextBox x:Name="tbFinishTime" Loaded="tbFinishTime_Loaded">
                                <TextBox.Text>
                                    <Binding Path="StopTime" UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <DataErrorValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <Label Content="Кол-во браузеров" />
                            <TextBox x:Name="tbBrowserCount" Loaded="tbBrowserCount_Loaded">
                                <TextBox.Text>
                                    <Binding Path="BrowserCount" UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <DataErrorValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Grid.ColumnSpan="5"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,26,0,0">
                            <TextBlock Text="Формат времени: 08:00:00. Кол-во браузеров - это сколько окон Chrome программа откроет одновременно."
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Grid.Row="3"
                                    Grid.ColumnSpan="5"
                                    Margin="0,18,0,0">
                            <CheckBox x:Name="cbBrowserEconomyMode"
                                      Content="Эконом-режим браузера"
                                      Loaded="cbBrowserEconomyMode_Loaded"
                                      Margin="0,0,0,10" />
                            <CheckBox x:Name="cbAntiDumpingEnabled"
                                      Content="Включить антидемпинг"
                                      Loaded="cbAntiDumpingEnabled_Loaded"
                                      Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="190" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Label Content="Порог демпинга, %" />
                                    <TextBox x:Name="tbAntiDumpingPercent"
                                             Loaded="tbAntiDumpingPercent_Loaded" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="Мин. конкурентов" />
                                    <TextBox x:Name="tbAntiDumpingMinOffers"
                                             Loaded="tbAntiDumpingMinOffers_Loaded" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <Label Content="Порог по низу ниже D, %" />
                                    <TextBox x:Name="tbLowestMaxBelowOrientirPercent"
                                             Loaded="tbLowestMaxBelowOrientirPercent_Loaded" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="4"
                                    Grid.ColumnSpan="5"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="Сохранить основные"
                                    Width="180"
                                    Click="Button_Click" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="tProxy" Header="Прокси">
                    <Grid Margin="8,20,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Куда сохранить"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,0,0,14" />
                            <RadioButton x:Name="rbAks"
                                         Content="Аксессуары"
                                         IsChecked="True"
                                         GroupName="Proxy" />
                            <RadioButton x:Name="rbPhone"
                                         Content="Смартфоны"
                                         IsChecked="False"
                                         GroupName="Proxy" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Логин" />
                            <TextBox x:Name="tbLogin" Margin="0,0,0,14" />
                            <Label Content="Пароль" />
                            <TextBox x:Name="tbPassword" Margin="0,0,0,14" />
                            <Label Content="Порт" />
                            <TextBox x:Name="tbPort" Margin="0,0,0,14" />
                            <Label Content="Ссылка смены IP" />
                            <TextBox x:Name="tbChangeIpUrl" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <Label Content="IP-адреса, каждый с новой строки" />
                            <RichTextBox x:Name="tbProxy"
                                         Height="260"
                                         Background="#F8FAFC"
                                         BorderBrush="{StaticResource LineBrush}"
                                         BorderThickness="1"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="10" />
                        </StackPanel>

                        <Button x:Name="btnSaveProxy"
                                Grid.Row="1"
                                Grid.ColumnSpan="5"
                                Content="Сохранить прокси"
                                Width="170"
                                HorizontalAlignment="Right"
                                Margin="0,18,0,0"
                                Click="btnSaveProxy_Click" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="tTelegram" Header="Telegram">
                    <ScrollViewer Margin="8,20,8,8"
                                  VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Label Content="Токен бота" />
                            <TextBox x:Name="tbTelegramBotToken"
                                     Loaded="tbTelegramBotToken_Loaded" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,18,0,18">
                            <TextBlock Text="ID групп или чатов можно указать по одному на строку. Поддерживаются числовые ID, например -1001234567890, и публичные @channelname."
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Grid.Row="2">
                            <Label Content="Группы / чаты для уведомлений" />
                            <RichTextBox x:Name="tbTelegramIds"
                                         Loaded="tbTelegramIds_Loaded"
                                         Height="82"
                                         Background="#F8FAFC"
                                         BorderBrush="{StaticResource LineBrush}"
                                         BorderThickness="1"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="10" />
                        </StackPanel>

                        <Grid Grid.Row="3" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       Text="В финальных сообщениях можно использовать: {processed}, {changed}, {errors}, {elapsed}."
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <Label Content="Смартфоны: старт" />
                                <RichTextBox x:Name="tbTelegramDefaultStartMessage"
                                             Loaded="tbTelegramDefaultStartMessage_Loaded"
                                             Height="74"
                                             Background="#F8FAFC"
                                             BorderBrush="{StaticResource LineBrush}"
                                             BorderThickness="1"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="10" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <Label Content="Смартфоны: финиш" />
                                <RichTextBox x:Name="tbTelegramDefaultFinishMessage"
                                             Loaded="tbTelegramDefaultFinishMessage_Loaded"
                                             Height="112"
                                             Background="#F8FAFC"
                                             BorderBrush="{StaticResource LineBrush}"
                                             BorderThickness="1"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="10" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,14,0,0">
                                <Label Content="Смартфоны: стоп" />
                                <RichTextBox x:Name="tbTelegramDefaultStopMessage"
                                             Loaded="tbTelegramDefaultStopMessage_Loaded"
                                             Height="74"
                                             Background="#F8FAFC"
                                             BorderBrush="{StaticResource LineBrush}"
                                             BorderThickness="1"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="10" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,14,0,0">
                                <Label Content="Аксессуары: старт" />
                                <RichTextBox x:Name="tbTelegramAksStartMessage"
                                             Loaded="tbTelegramAksStartMessage_Loaded"
                                             Height="74"
                                             Background="#F8FAFC"
                                             BorderBrush="{StaticResource LineBrush}"
                                             BorderThickness="1"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="10" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,14,0,0">
                                <Label Content="Аксессуары: финиш" />
                                <RichTextBox x:Name="tbTelegramAksFinishMessage"
                                             Loaded="tbTelegramAksFinishMessage_Loaded"
                                             Height="112"
                                             Background="#F8FAFC"
                                             BorderBrush="{StaticResource LineBrush}"
                                             BorderThickness="1"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="10" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,14,0,0">
                                <Label Content="Аксессуары: стоп" />
                                <RichTextBox x:Name="tbTelegramAksStopMessage"
                                             Loaded="tbTelegramAksStopMessage_Loaded"
                                             Height="74"
                                             Background="#F8FAFC"
                                             BorderBrush="{StaticResource LineBrush}"
                                             BorderThickness="1"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="10" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="4"
                                    Margin="0,18,0,0">
                            <CheckBox x:Name="cbMorningReportEnabled"
                                      Content="Включить утренний Telegram-отчет"
                                      Loaded="cbMorningReportEnabled_Loaded"
                                      Margin="0,0,0,10" />
                            <StackPanel Width="210"
                                        HorizontalAlignment="Left">
                                <Label Content="Время отчета" />
                                <TextBox x:Name="tbMorningReportTime"
                                         Loaded="tbMorningReportTime_Loaded" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Row="5"
                                x:Name="btnSaveTelegram"
                                Content="Сохранить Telegram"
                                Width="190"
                                HorizontalAlignment="Right"
                                Margin="0,18,0,0"
                                Click="btnSaveTelegram_Click" />
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="tableSetting" Header="Столбцы">
                    <Grid Margin="8,18,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="180" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" MinWidth="180" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" MinWidth="180" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Диапазон от" />
                            <TextBox x:Name="tbOtDiapazon" Loaded="tbOtDiapazon_Loaded" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Диапазон до" />
                            <TextBox x:Name="tbDoDiapazon" Loaded="tbDoDiapazon_Loaded" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <Label Content="Цена ориентир" />
                            <TextBox x:Name="tbPriceOrientir" Loaded="tbPriceOrientir_Loaded" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,18,0,0">
                            <Label Content="Результат парсинга" />
                            <TextBox x:Name="tbPriceResult" Loaded="tbPriceResult_Loaded" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,18,0,0">
                            <Label Content="РРЦ цена" />
                            <TextBox x:Name="tbPriceRRC" Loaded="tbPriceRRC_Loaded" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,18,0,0">
                            <Label Content="Кол-во предложений" />
                            <TextBox x:Name="tbColPredlogeniy" Loaded="tbColPredlogeniy_Loaded" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Grid.ColumnSpan="5"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,26,0,0">
                            <TextBlock Text="Используйте буквенные обозначения колонок Google Sheets, например A, F, AC."
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Grid.Row="4"
                                    Grid.ColumnSpan="5"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,18,0,0">
                            <Button x:Name="btnNormalizeOrientir"
                                    Content="Обновить D по ОПТ"
                                    Width="180"
                                    Margin="0,0,12,0"
                                    Click="btnNormalizeOrientir_Click" />
                            <Button x:Name="btnSaveProxy2"
                                    Content="Сохранить столбцы"
                                    Width="170"
                                    Click="btnSaveProxy_Click2" />
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
